{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": {
          "type": "string",
          "description": "Firebase Auth UID"
        },
        "email": {
          "type": "string",
          "format": "email"
        },
        "displayName": {
          "type": "string"
        },
        "photoURL": {
          "type": "string",
          "format": "uri"
        },
        "role": {
          "type": "string",
          "enum": ["user", "admin"]
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": ["uid", "email", "role", "createdAt"]
    },
    "Score": {
      "title": "Score",
      "description": "User game score",
      "type": "object",
      "properties": {
        "uid": {
          "type": "string",
          "description": "User ID"
        },
        "game": {
          "type": "string",
          "description": "Name of the game"
        },
        "score": {
          "type": "number",
          "description": "Score achieved"
        },
        "language": {
          "type": "string",
          "description": "Target language"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": ["uid", "game", "score", "language", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": {
        "$ref": "#/entities/User"
      },
      "description": "User profiles"
    },
    "/scores/{scoreId}": {
      "schema": {
        "$ref": "#/entities/Score"
      },
      "description": "Game scores"
    }
  }
}
